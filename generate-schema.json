        "properties": {
          "above": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/segment"
            }
          }
        }
      },
      "columns": {
        "type": "object",
        "required": [
          "besides"
        ],
        "properties": {
          "besides": {
            "type": "array",
            "minItems": 2,
            "items": {
              "anyOf": [
                {
                  "$ref": "#/$defs/segment"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "widths": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12
            }
          }
        }
      },
